# 1. dependencies (المجلدات التي تحمل حزم الأكواد)
node_modules/
/jspm_packages/

# 2. Next.js build output (مخرجات بناء المشروع المؤقتة والنهائية)
.next/
out/

# 3. Production build (ملفات البناء والإنتاج)
build/
dist/

# 4. Environment Variables (الملفات الحساسة التي تحتوي على المفاتيح وقواعد البيانات)
# مهم جداً ألا ترفع هذه الملفات لحماية بياناتك السرية
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env.local

# 5. Debug and Logs (ملفات سجلات الأخطاء والتشغيل)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 6. IDEs and Editors (إعدادات محررات الأكواد الخاصة بجهازك الشخصي)
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 7. OS Metadata (ملفات النظام الشخصي المؤقتة للويندوز والماك)
.DS_Store
Thumbs.db